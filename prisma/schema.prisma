datasource db {
  provider = "postgresql"
  url      = env("blogairborne_PRISMA_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model BlogPost {
  id             String   @id @default(uuid())
  title          String
  slug           String   @unique
  content        String?
  summary        String?
  published      Boolean  @default(false)
  
  // Scheduling & AI Auto-Generation fields
  publishAt         DateTime?
  contentPillar     String?
  primaryKeyword    String?
  secondaryKeywords String?
  wordCount         String?
  isAutoGenerated   Boolean  @default(false)
  generationStatus  String   @default("COMPLETED") // PENDING, COMPLETED, FAILED

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // SEO fields
  seoTitle       String?
  seoDescription String?
  keywords       String? // Comma-separated keywords
  
  // GEO fields
  targetLocation String? // e.g., "Chicago, IL"
  targetRegion   String? // e.g., "US-IL" (ISO code)
  latitude       Float?
  longitude      Float?
  radiusKm       Float?   @default(50)
  
  analytics      BlogAnalytics[]
}

model DemoRequest {
  id        String   @id @default(uuid())
  email     String
  name      String?
  company   String?
  phone     String?
  message   String?
  createdAt DateTime @default(now())
}

model BlogAnalytics {
  id             String   @id @default(uuid())
  blogPostId     String
  blogPost       BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  
  // Viewer Information
  ipHash         String?  // Anonymized IP hash or uniquely identifiable string for unique views
  userAgent      String?
  country        String?
  city           String?
  region         String?
  
  // Engagement Data
  scrollDepth    Float    @default(0) // Percentage 0-100
  timeSpentSec   Int      @default(0) // Seconds spent actively reading
  
  viewedAt       DateTime @default(now())
}
