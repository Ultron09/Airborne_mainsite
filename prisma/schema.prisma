datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model BlogPost {
  id             String   @id @default(uuid())
  title          String
  slug           String   @unique
  content        String
  summary        String
  published      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // SEO fields
  seoTitle       String?
  seoDescription String?
  keywords       String? // Comma-separated keywords
  
  // GEO fields
  targetLocation String? // e.g., "Chicago, IL"
  targetRegion   String? // e.g., "US-IL" (ISO code)
  latitude       Float?
  longitude      Float?
  radiusKm       Float?   @default(50)
}
